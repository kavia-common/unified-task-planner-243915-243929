# FastAPI Backend Environment Variables (example)
# NOTE: Do not commit real secrets. Ask orchestrator to set these in the container .env.

# Optional: override DB connection (otherwise backend tries postgresql_database/db_connection.txt)
DATABASE_URL=postgresql+asyncpg://appuser:dbuser123@localhost:5000/myapp

# JWT settings
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=30
REFRESH_TOKEN_EXPIRES_DAYS=14

# CORS (comma-separated)
CORS_ALLOW_ORIGINS=*
APP_NAME=Unified Task Planner API
APP_VERSION=0.2.0
